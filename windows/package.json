{
  "name": "trace-windows",
  "version": "0.3.9",
  "description": "Windows desktop parity build for Trace.",
  "main": "main.js",
  "author": "AITopia Shao",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --x64 --publish never"
  },
  "dependencies": {
    "katex": "^0.16.22"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "local.trace",
    "productName": "Trace",
    "directories": {
      "output": "dist"
    },
    "artifactName": "Trace-v${version}-Windows-${arch}-Setup.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json",
      "node_modules/katex/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Trace"
    }
  }
}
